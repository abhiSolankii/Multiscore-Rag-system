# Server Settings
PORT=8000
HOST=0.0.0.0
PROJECT_NAME="Multiscore RAG"

# MongoDB Settings
MONGODB_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/multiscore_rag
DATABASE_NAME=multiscore_rag

# Security Settings
# Generate: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=deepseek/deepseek-chat

# ── RAG ────────────────────────────────────────────────────────────────────

# Master switch (set true to enable RAG on chat)
RAG_ENABLED=false

# Vector DB (Qdrant)
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=multiscore_docs

# Embedding — uses a separate OpenAI-compatible API (NOT OpenRouter)
# See RAG_README.md for why embeddings use a separate key
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...

# Reranker (runs locally, no API key needed)
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-large

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVAL_TOP_K=5
HYBRID_SEARCH_ENABLED=true

# File storage (local, relative to backend dir)
UPLOAD_DIR=./uploads

# Logging (set true to see DEBUG level output in console + logs/app.log)
DEBUG_LOGGING=true
# Stream Responses
ENABLE_STREAMING=true
